
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>My Company Website</title>
    <link rel="stylesheet" href="style.css">
</head>
<body>

<header>
    <h1>My Company</h1>
    <nav>
        <a href="#home">Home</a>
        <a href="#about">About</a>
        <a href="#services">Services</a>
        <a href="#contact">Contact</a>
    </nav>
</header>

<section id="home">
    <h2>Welcome to Our Company</h2>
    <p>We provide modern digital solutions for your business.</p>
</section>

<section id="about">
    <h2>About Us</h2>
    <p>We are a professional company delivering quality services worldwide.</p>
</section>

<section id="services">
    <h2>Our Services</h2>
    <ul>
        <li>Website Design</li>
        <li>App Development</li>
        <li>Digital Marketing</li>
    </ul>
</section>

<section id="contact">
    <h2>Contact Us</h2>
    <p>Email: info@mycompany.com</p>
</section>

<footer>
    <p>© 2026 My Company</p>
</footer>

</body>
</html>
